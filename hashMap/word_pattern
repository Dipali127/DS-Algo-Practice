// LeetCode Problem: Word Pattern

// Approach: Using Hash Map

// A bijection (or bijective function) is a function that creates a one-to-one correspondence 
// between elements of two sets. This means every element in one set is paired with exactly one 
// unique element in the other set, and vice versa.

// Steps:
// 1. Convert the pattern string into an array of characters and the string `s` into an array of words.
// 2. Check if the length of the pattern is not equal to the number of words in `s`. If so, return false.
// 3. Use two maps:
//    - mapPattern: to store mapping from pattern character → word
//    - mapS: to store mapping from word → pattern character
// 4. Traverse the pattern array:
//    - If the character already exists in mapPattern, check if it maps to the same word.
//      If not, return false.
//    - Otherwise, store the mapping.
// 5. Traverse the word array:
//    - If the word already exists in mapS, check if it maps to the same pattern character.
//      If not, return false.
//    - Otherwise, store the mapping.
// 6. If all mappings are consistent, return true.

// Time Complexity: O(N)
// - We traverse the pattern and word arrays once each.

// Space Complexity: O(N)
// - Extra space is used to store mappings in mapPattern and mapS.

var wordPattern = function (pattern, s) {
    pattern = pattern.split('');
    s = s.split(' ');
    if (pattern.length !== s.length) {
        return false;
    }
    let mapPattern = new Map();
    let mapS = new Map();
    for (let i = 0; i < pattern.length; i++) {
        if (mapPattern.has(pattern[i])) {
            if (mapPattern.get(pattern[i]) !== s[i]) {
                return false;
            }
        } else {
            mapPattern.set(pattern[i], s[i]);
        }
    }

    for (let i = 0; i < s.length; i++) {
        if (mapS.has(s[i])) {
            if (mapS.get(s[i]) !== pattern[i]) {
                return false;
            }
        } else {
            mapS.set(s[i], pattern[i]);
        }
    }

    return true;
};